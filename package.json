{
  "name": "hfo-cli",
  "version": "0.1.0",
  "description": "A fullscreen terminal UI to discover, install, tune, manage, launch, back up and restore Hugging Face GGUF models through Ollama — auto-tuned to your hardware.",
  "keywords": [
    "ollama",
    "llm",
    "gguf",
    "huggingface",
    "tui",
    "terminal",
    "cli",
    "ai",
    "local-llm",
    "ink",
    "react",
    "agent",
    "claude-code",
    "codex",
    "copilot",
    "backup",
    "restore"
  ],
  "homepage": "https://hfo.carrillo.app",
  "bugs": {
    "url": "https://github.com/carrilloapps/hfo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carrilloapps/hfo.git"
  },
  "author": {
    "name": "José Carrillo",
    "email": "m@carrillo.app",
    "url": "https://carrillo.app"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "hfo": "./bin/hfo.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "start": "node bin/hfo.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "skills:install": "node scripts/install-skills.mjs",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run build",
    "link": "npm link"
  },
  "dependencies": {
    "adm-zip": "~0.5.17",
    "archiver": "~7.0.1",
    "execa": "~9.5.2",
    "figures": "~6.1.0",
    "ink": "~7.0.1",
    "ink-select-input": "~6.2.0",
    "ink-spinner": "~5.0.0",
    "ink-text-input": "~6.0.0",
    "meow": "~13.2.0",
    "react": "~19.2.5",
    "systeminformation": "~5.23.14"
  },
  "devDependencies": {
    "@types/adm-zip": "~0.5.8",
    "@types/archiver": "~7.0.0",
    "@types/node": "~22.10.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "~8.59.0",
    "@typescript-eslint/parser": "~8.59.0",
    "eslint": "~9.17.0",
    "tsx": "~4.19.2",
    "typescript": "~5.7.2",
    "vitest": "~2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.1",
  "publishConfig": {
    "access": "public"
  },
  "pkg": {
    "targets": [
      "node22-linux-x64",
      "node22-linux-arm64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-win-x64"
    ],
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "package.json",
      "node_modules/figures/**/*",
      "node_modules/ink/**/*",
      "node_modules/systeminformation/**/*"
    ],
    "outputPath": "dist-bin"
  }
}
